# LLM API Keys
GOOGLE_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
LLM_PROVIDER=google
LLM_MODEL=gemini-1.5-flash

# Serper Search Tool (optional)
SERPER_API_KEY=your-serper-api-key
ENABLE_SERPER_SEARCH=false

# MCP Docs Research (optional)
ENABLE_MCP_RESEARCH=false
MCP_SERVER_CONFIG_PATH=./mcp_servers.json
MCP_DOCS_SERVER_NAME=docs
MCP_DOCS_TOOL_NAME=search_docs

# GitHub (optional, for private repos)
GITHUB_TOKEN=your-github-personal-access-token

# App Settings
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=sqlite+aiosqlite:///./spring2fast.db

# Output Directory
OUTPUT_DIR=./output
WORKSPACE_DIR=./workspace
